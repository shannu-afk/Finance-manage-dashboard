{
  "info": {
    "name": "PFM Dashboard API",
    "description": "Personal Finance Management Dashboard API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/api/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"passwordConfirm\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Get All Accounts",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/accounts",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ]
          }
        },
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "url": "http://localhost:5000/api/accounts",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountName\": \"My Checking Account\",\n  \"accountType\": \"checking\",\n  \"balance\": 5000\n}"
            }
          }
        },
        {
          "name": "Get Total Balance",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/accounts/balance/total",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ]
          }
        },
        {
          "name": "Update Account",
          "request": {
            "method": "PUT",
            "url": "http://localhost:5000/api/accounts/ACCOUNT_ID",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"balance\": 6000\n}"
            }
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:5000/api/accounts/ACCOUNT_ID",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/accounts/transactions/all",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ]
          }
        },
        {
          "name": "Get Spending by Category",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/accounts/analytics/spending",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ]
          }
        },
        {
          "name": "Get Monthly Trend",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/api/accounts/analytics/trend",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_JWT_TOKEN"
              }
            ]
          }
        }
      ]
    }
  ]
}
